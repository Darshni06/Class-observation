rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function myClassId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.classId;
    }

    // Every signed-in user (admin or teacher) belongs to exactly one
    // department. All cross-department visibility is blocked by comparing
    // this against each document's own `departmentId` field.
    function myDepartmentId() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.departmentId;
    }

    // ── users ──────────────────────────────────────────────────────────
    // Anyone can read their own profile (needed for login).
    // Admin can read/manage other users only within their own department.
    match /users/{uid} {
      allow read: if isOwner(uid) ||
        (isAdmin() && resource.data.departmentId == myDepartmentId());
      allow create: if isAdmin() && request.resource.data.departmentId == myDepartmentId();
      allow update, delete: if isAdmin() && resource.data.departmentId == myDepartmentId();
    }

    // ── classes ────────────────────────────────────────────────────────
    // Read/write scoped to your own department — covers both admin and
    // teacher access uniformly, no role check needed for read.
    match /classes/{classId} {
      allow read: if isSignedIn() && resource.data.departmentId == myDepartmentId();
      allow create: if isAdmin() && request.resource.data.departmentId == myDepartmentId();
      allow update, delete: if isAdmin() && resource.data.departmentId == myDepartmentId();
    }

    // ── observations ───────────────────────────────────────────────────
    // Scoped to department first, then to admin-or-own-class as before.
    match /observations/{obsId} {
      allow read: if isSignedIn() && resource.data.departmentId == myDepartmentId();
      allow create: if isSignedIn() && request.resource.data.departmentId == myDepartmentId() &&
        (isAdmin() || request.resource.data.classId == myClassId());
      allow update, delete: if isSignedIn() && resource.data.departmentId == myDepartmentId() &&
        (isAdmin() || resource.data.classId == myClassId());
    }

    // ── reports ────────────────────────────────────────────────────────
    match /reports/{reportId} {
      allow read: if isSignedIn() && resource.data.departmentId == myDepartmentId() &&
        (isAdmin() || resource.data.sharedWithTeacher == true);
      allow create: if isSignedIn() && request.resource.data.departmentId == myDepartmentId() &&
        (isAdmin() || request.resource.data.classId == myClassId());
      allow update, delete: if isSignedIn() && resource.data.departmentId == myDepartmentId() &&
        (isAdmin() || resource.data.classId == myClassId());
    }
  }
}
